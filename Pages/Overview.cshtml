<div class="admPanels">
    <div class="admMenu">
        <p><b>Program</b></p>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/Admin")'">Draft a Schedule</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/DeleteSchedules")'">Manage Schedules</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/InstructorLoading")'">Instructor Management</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/RoomManagement")'">Room Management</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/SubjectManagement")'">Subjects Management</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/CourseManagement")'">Course Management</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/Signup")'">Create Account</button>
        <button class="sideBtn" onclick="window.location.href='@Url.Page("/Accounts")'">Manage Account</button>
    </div>

    <!-- RIGHT PANEL FOR SCHEDULES -->
    <div class="schedulePanel">
        <h3><b>SCHEDULES:</b></h3>

        @foreach (var day in Model.Days)
        {
            <h3>@day</h3>

            @* --- ROOMS --- *@
            <div class="categoryContainer">
                <div class="categoryBtnsRow">
                    @foreach (var room in Model.RoomsPerDay[day])
                    {
                        <button class="toggleBtn blueBtn" data-type="room" data-day="@day" data-name="@room">
                            @room
                        </button>
                    }
                </div>
                @foreach (var room in Model.RoomsPerDay[day])
                {
                    <div class="scheduleTableContainer" id="room-@day-@room.Replace(" ", "_")" style="display:none;">
                        <table class="scheduleTable">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Subject</th>
                                    <th>Section</th>
                                    <th>Instructor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.SchedulesByDay[day].Where(x => x.Room == room).OrderBy(x => x.Start))
                                {
                                    <tr>
                                        <td>@s.Start.ToString(@"h\:mm") - @s.End.ToString(@"h\:mm")</td>
                                        <td>@s.Subject</td>
                                        <td>@s.Section</td>
                                        <td>@s.Instructor</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* --- INSTRUCTORS --- *@
            <div class="categoryContainer">
                <div class="categoryBtnsRow">
                    @foreach (var instr in Model.InstructorsPerDay[day])
                    {
                        <button class="toggleBtn blueBtn" data-type="instructor" data-day="@day" data-name="@instr">
                            @instr
                        </button>
                    }
                </div>
                @foreach (var instr in Model.InstructorsPerDay[day])
                {
                    <div class="scheduleTableContainer" id="instructor-@day-@instr.Replace(" ", "_")" style="display:none;">
                        <table class="scheduleTable">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Room</th>
                                    <th>Subject</th>
                                    <th>Section</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.SchedulesByDay[day].Where(x => x.Instructor == instr).OrderBy(x => x.Start))
                                {
                                    <tr>
                                        <td>@s.Start.ToString(@"h\:mm") - @s.End.ToString(@"h\:mm")</td>
                                        <td>@s.Room</td>
                                        <td>@s.Subject</td>
                                        <td>@s.Section</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* --- SECTIONS --- *@
            <div class="categoryContainer">
                <div class="categoryBtnsRow">
                    @foreach (var sec in Model.AllSections)
                    {
                        <button class="toggleBtn blueBtn" data-type="section" data-day="@day" data-name="@sec">
                            @sec
                        </button>
                    }
                </div>
                @foreach (var sec in Model.AllSections)
                {
                    <div class="scheduleTableContainer" id="section-@day-@sec.Replace(" ", "_")" style="display:none;">
                        <table class="scheduleTable">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Subject</th>
                                    <th>Instructor</th>
                                    <th>Room</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.SchedulesByDay[day].Where(x => x.Section == sec).OrderBy(x => x.Start))
                                {
                                    <tr>
                                        <td>@s.Start.ToString(@"h\:mm") - @s.End.ToString(@"h\:mm")</td>
                                        <td>@s.Subject</td>
                                        <td>@s.Instructor</td>
                                        <td>@s.Room</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>


<script>
    document.querySelectorAll(".toggleBtn").forEach(btn => {
        btn.addEventListener("click", () => {
            const type = btn.getAttribute("data-type");
            const day = btn.getAttribute("data-day");
            const name = btn.getAttribute("data-name").replace(/\s/g, "_"); // sanitize spaces
            const divId = `${type}-${day}-${name}`;
            const tableDiv = document.getElementById(divId);

            // Hide all other tables in the same category for this day
            document.querySelectorAll(`.scheduleTableContainer[id^="${type}-${day}-"]`).forEach(d => {
                if(d.id !== divId) d.style.display = "none";
            });

            // Toggle current
            tableDiv.style.display = tableDiv.style.display === "none" ? "block" : "none";
        });
    });

</script>

