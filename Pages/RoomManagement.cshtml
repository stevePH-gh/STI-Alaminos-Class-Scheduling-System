<h1><b>Room Management</b></h1>

<!-- Add Room Form -->
<div class="formContainer">
    <h3>Add Room</h3>
    <form method="post">
        <div class="row">
            <div style="flex:1; display:flex; flex-direction:column;">
                <p style="margin:0 0 5px 0;">Room Name</p>
                <input asp-for="NewRoom.RoomName" placeholder="Enter Room Name" autocomplete="off" />
            </div>

            <div style="flex:1; display:flex; flex-direction:column;">
                <p style="margin:0 0 5px 0;">Type</p>
                <select asp-for="NewRoom.Type">
                    <option value="" disabled selected>Select Type</option>
                    <option value="Regular">Regular Room</option>
                    <option value="Laboratory">Laboratory Room</option>
                </select>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <p style="color:red">@Model.Message</p>
        }

        <div class="row btnRow">
            <button type="submit" class="btnCreate">Add Room</button>
            <button type="button" class="btnBack" onclick="window.location.href='@Url.Page("/Overview")'">Back</button>
        </div>
    </form>
</div>

<h3>Existing Rooms</h3>

<form method="post" asp-page-handler="ExportAll">
    <button type="submit" class="exportBtn" style="width:100%; margin-bottom:15px;">
        Export Data
    </button>
</form>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Room Name</th>
            <th>Type</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model.Rooms)
        {
            <tr>
                <td>@room.Id</td>
                <td>@room.RoomName</td>
                <td>@room.Type</td>
                <td>
                    <button type="button"
                            class="btnDelete"
                            onclick="openFirstConfirm(@room.Id)">
                        Delete
                    </button>

                </td>
            </tr>
        }
    </tbody>
</table>

<!-- FIRST CONFIRM POPUP -->
<div id="confirmModal1" class="modal" style="display:none;">
    <div class="modal-content">
        <h3>Confirm Delete</h3>
        <p>Are you sure you want to delete this room?</p>
        <button class="btnDelete" onclick="openSecondConfirm()">Yes</button>
        <button class="btnBack" onclick="closeFirstConfirm()">Cancel</button>
    </div>
</div>

<!-- SECOND CONFIRM POPUP (TYPE DELETE) -->
<div id="confirmModal2" class="modal" style="display:none;">
    <div class="modal-content">
        <h3>Final Confirmation</h3>
        <p>Type <b>DELETE</b> to confirm:</p>

        <input id="deleteVerifyInput" type="text" placeholder="Type DELETE" style="padding:10px; width:80%;" />

        <form id="finalDeleteForm" method="post" asp-page-handler="Delete" style="margin-top:15px;">
            <input type="hidden" id="finalDeleteId" name="id" />
            <button type="submit" class="btnDelete" id="finalDeleteBtn" disabled>Confirm Delete</button>
            <button type="button" class="btnBack" onclick="closeSecondConfirm()">Cancel</button>
        </form>
    </div>
</div>

<script>
    let currentDeleteId = 0;

    function openFirstConfirm(id) {
        currentDeleteId = id;
        document.getElementById("confirmModal1").style.display = "flex";
    }

    function closeFirstConfirm() {
        document.getElementById("confirmModal1").style.display = "none";
    }

    function openSecondConfirm() {
        closeFirstConfirm();
        document.getElementById("confirmModal2").style.display = "flex";
        document.getElementById("finalDeleteId").value = currentDeleteId;
        document.getElementById("deleteVerifyInput").value = "";
        document.getElementById("finalDeleteBtn").disabled = true;
    }

    function closeSecondConfirm() {
        document.getElementById("confirmModal2").style.display = "none";
    }

    document.addEventListener("input", function () {
        const input = document.getElementById("deleteVerifyInput").value.trim();
        const btn = document.getElementById("finalDeleteBtn");

        btn.disabled = (input !== "DELETE");
    });
</script>


<style>
    /* Container styling */
    .formContainer {
        margin-top: 20px;
        padding: 20px;
        border-radius: 8px;
        background-color: #eee;
        color: black;
    }

    /* Rows */
    .row {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
    }

    /* Inputs and select */
    input, select {
        padding: 10px;
        border-radius: 5px;
        border: 1px solid #ccc;
        flex: 1;
        font-size: 14px;
    }

        /* Inputs focus */
        input:focus, select:focus {
            outline: none;
            border-color: #035f82;
            box-shadow: 0 0 4px rgba(3,95,130,0.3);
        }

    /* Buttons */
    .btnCreate {
        background-color: #047eaf;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

        .btnCreate:hover {
            background-color: #035f82;
        }

    .btnBack {
        background-color: gray;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

        .btnBack:hover {
            background-color: #555;
        }

    /* Table styling */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
        background-color: white;
        color: black;
    }

        table th, table td {
            border: 1px solid #ccc;
            padding: 8px 12px;
            text-align: left;
        }

        table th {
            background-color: #f0f0f0;
        }

    /* Messages */
    p {
        margin: 5px 0;
    }

    .btnDelete {
        background-color: #c62828;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
    }

        .btnDelete:hover {
            background-color: #a61c1c;
        }

    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: none;
        align-items: center;
        justify-content: center;
    }

    .modal-content {
        background: white;
        padding: 20px;
        border-radius: 10px;
        width: 350px;
        text-align: center;
    }

</style>
