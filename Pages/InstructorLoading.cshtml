<h1><b>Instructor Management</b></h1>

<form method="post">
    <div class="row" style="display: flex; gap: 10px;">
        <div style="display: flex; flex-direction: column; flex: 1;">
            <p style="margin: 0 0 5px 0;">First Name</p>
            <input asp-for="NewInstructor.FirstName" placeholder="First Name" autocomplete="off" required />
        </div>

        <div style="display: flex; flex-direction: column; flex: 1;">
            <p style="margin: 0 0 5px 0;">Last Name</p>
            <input asp-for="NewInstructor.LastName" placeholder="Last Name" autocomplete="off" required />
        </div>
    </div>

    <div class="row">
        <select asp-for="NewInstructor.Type" required>
            <option value="" disabled selected>Select Subject Scope</option>
            @foreach (var type in Model.Types)
            {
                <option value="@type">@type</option>
            }
            <option value="Generic Subject">Generic Subject</option>
        </select>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p style="color: red;">@Model.Message</p>
    }

    <div class="row btnRow">
        <button type="submit" class="btnCreate">Register Instructor</button>
        <button type="button" class="btnBack" onclick="window.location.href='@Url.Page("/Overview")'">Back</button>
    </div>
</form>

<h3>Existing Instructors</h3>

<form method="post" asp-page-handler="ExportAll">
    <button type="submit" class="exportBtn" style="width:100%; margin-bottom:15px;">
        Export Data
    </button>
</form>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Course</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var instructor in Model.Instructors)
        {
            <tr>
                <td>@instructor.Id</td>
                <td>@instructor.FirstName</td>
                <td>@instructor.LastName</td>
                <td>@instructor.Type</td>
                <td>
                    <button type="button" class="btnDelete" onclick="openConfirm(@instructor.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- DELETE CONFIRM MODAL -->
<div id="confirmModal" class="modal" style="display:none;">
    <div class="modal-content">
        <h3>Confirm Delete</h3>
        <p>Are you sure you want to delete this instructor?</p>
        <form method="post" asp-page-handler="Delete">
            <input type="hidden" id="deleteId" name="id" />
            <button type="submit" class="btnDelete">Yes, Delete</button>
            <button type="button" class="btnBack" onclick="closeConfirm()">Cancel</button>
        </form>
    </div>
</div>

<script>
    let currentDeleteId = 0;

    function openConfirm(id) {
        currentDeleteId = id;
        document.getElementById("deleteId").value = currentDeleteId;
        document.getElementById("confirmModal").style.display = "flex";
    }

    function closeConfirm() {
        document.getElementById("confirmModal").style.display = "none";
    }
</script>

<style>
    .row {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
    }

    input, select {
        padding: 8px;
        border-radius: 5px;
        border: 1px solid #ccc;
        flex: 1;
    }

    .btnCreate {
        background-color: #047eaf;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

        .btnCreate:hover {
            background-color: #035f82;
        }

    .btnBack {
        background-color: gray;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

        .btnBack:hover {
            background-color: #555;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
        background-color: white;
    }

        table th, table td {
            border: 1px solid #ccc;
            padding: 8px 12px;
            text-align: left;
        }

        table th {
            background-color: #f0f0f0;
        }

    .btnDelete {
        background-color: #c62828;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
    }

        .btnDelete:hover {
            background-color: #a61c1c;
        }

    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-content {
        background-color: white;
        padding: 20px;
        border-radius: 8px;
        width: 400px;
        max-width: 90%;
        text-align: center;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
    }
</style>
